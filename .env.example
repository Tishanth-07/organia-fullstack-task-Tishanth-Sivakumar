# ── 1. Database Configuration ───────────────────────────────────────────────
# PostgreSQL settings used by both the 'db' service and the backend connection string.
POSTGRES_USER=nintro_admin
POSTGRES_PASSWORD=nintro_secure_local_pass
POSTGRES_DB=nintro_db
DB_PORT=5432

# ── 2. Security & Authentication ────────────────────────────────────────────
# JWT secret key (must be at least 32 characters for HS256)
JWT_KEY=your_secure_32_char_secret_key_placeholder
JWT_ISSUER=nintro-auth-provider
JWT_AUDIENCE=nintro-client-app

# ── 3. Networking & Infrastructure ──────────────────────────────────────────
# Exposed ports for the services
BACKEND_PORT=5181
FRONTEND_PORT=3000

# API communication URL used by the Next.js frontend
NEXT_PUBLIC_API_URL=http://localhost:5181/api

# CORS configuration: comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ── 4. SMTP / Email Service ────────────────────────────────────────────────
# Required for account verification and password resets
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL=noreply@nintro.com
FROM_NAME=Nintro Platform

# ── 5. Application Environment ─────────────────────────────────────────────
# Set to 'Production' for final deployment
ASPNETCORE_ENVIRONMENT=Development
AUTO_MIGRATE=true
